# === LLM API ===
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# OPENAI_API_KEY=

# === Supabase (클라우드 단일 인스턴스) ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === 시장 데이터 ===
# 무료 소스로 시작. 키가 필요한 소스를 쓸 경우에만 채운다.
MARKET_DATA_API_KEY=

# === 투자 엔진 설정 ===
# 모의체결 규칙 (확정: 판단 당시가 + 슬리피지 즉시 체결)
FILL_RULE=IMMEDIATE_PRICE_PLUS_SLIPPAGE
SLIPPAGE_BPS=5
FEE_BPS=1

# === 한국투자증권(KIS) — 인트라데이 시세 메인 소스 ===
KIS_APP_KEY=
KIS_APP_SECRET=
# KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# === 급락 모니터 워커 ===
DISCORD_WEBHOOK_URL=
MONITOR_SYMBOLS=005930,SPY,QQQ        # 쉼표구분, 최대 50개 내외
MONITOR_PORTFOLIO_IDS=                # 자동매매 대상 포트폴리오(쉼표구분)
MONITOR_INTERVAL_MS=300000            # 5분
DAILY_DROP_PCT=3                      # 전일대비 -3% 트리거
INTRADAY_DROP_PCT=5                   # 당일고가대비 -5% 트리거
ALERT_COOLDOWN_MS=1800000             # 같은 종목 재알림 쿨다운(30분)
ENABLE_AUTO_TRADE=false              # 급락 시 자동 모의매수 여부

# === 서비스 ===
INVESTMENT_CORE_PORT=4001
LOG_LEVEL=info
